PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# Use mock for offline demos, real for external API backed providers with fallback.
PROVIDER_MODE=mock

# Real provider keys. Keep empty to fallback to mock behavior for that provider.
# Korea Tourism Organization TourAPI service key for nearby alternatives.
TOUR_API_SERVICE_KEY=

# Seoul Open Data API key for realtime city crowd data.
SEOUL_OPEN_API_KEY=

# OSRM-compatible route API base URL. Used only when both origin and destination coordinates are provided.
OSRM_BASE_URL=https://router.project-osrm.org

# Optional custom accessibility aggregator URL.
# Expected query: ?lat=37.0&lng=127.0
# Expected JSON: {"restroomNearby":true,"nursingRoomNearby":false,"indoorWaitNearby":true}
ACCESSIBILITY_API_URL=
